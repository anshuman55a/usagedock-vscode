.vscode-test
*.vsix
.git/**
.vscode/**
src/**
webview/**
tsconfig.json
vite.config.webview.ts
package-lock.json
.gitignore

# The extension host and webview are bundled into dist.
node_modules/**

# Runtime SQLite native dependency kept because better-sqlite3 is externalized.
!node_modules/better-sqlite3/**
!node_modules/bindings/**
!node_modules/file-uri-to-path/**

# Drop build/source-only files from the native dependency.
node_modules/better-sqlite3/src/**
node_modules/better-sqlite3/deps/**
node_modules/better-sqlite3/binding.gyp
node_modules/better-sqlite3/README.md
node_modules/bindings/README.md
